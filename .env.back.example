# ========================
# Mamoji 后端环境配置模板
# ========================
# 复制此文件为 backend/.env
# cp .env.back.example backend/.env

# 服务器端口
SERVER_PORT=38080

# H2 数据库配置 (开发用)
SPRING_DATASOURCE_URL=jdbc:h2:mem:mamoji
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# H2 控制台 (开发用)
SPRING_H2_CONSOLE_ENABLED=true
SPRING_H2_CONSOLE_PATH=/h2-console

# JWT 配置 (生产环境必须修改)
JWT_SECRET=change-this-to-a-secure-secret-key-at-least-64-characters-long
JWT_EXPIRATION=86400

# 日志级别
LOG_LEVEL=INFO
LOG_LEVEL_SECURITY=INFO

# Java 环境 (使用 Corretto 21)
# JAVA_HOME=C:\Users\pearf\.jdks\corretto-21.0.10

# AI 配置
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.5
