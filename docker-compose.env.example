# ============================================================
# Docker Compose 环境变量配置
# ============================================================
#
# 使用方法：
# 1. 复制此文件为 .env
# 2. 修改相应的值（不要提交 .env 到版本控制）
#
# ============================================================

# ============================================================
# 基础配置
# ============================================================

# 激活的 Profile（dev/test/prod）
SPRING_PROFILES_ACTIVE=dev

# ============================================================
# MySQL 配置
# ============================================================

# MySQL 端口
MYSQL_PORT=3306

# MySQL root 密码（生产环境必须修改！）
MYSQL_ROOT_PASSWORD=mamoji_root_pass

# MySQL 数据库名
MYSQL_DATABASE=mamoji

# MySQL 用户名和密码
DB_USER=mamoji_mysql
DB_PASSWORD=mamoji_mysql_pass

# ============================================================
# Redis 配置
# ============================================================

# Redis 端口
REDIS_PORT=6379

# Redis 密码（生产环境必须修改！）
REDIS_PASSWORD=mamoji_redis_pass

# ============================================================
# 后端配置
# ============================================================

# 后端端口
BACKEND_PORT=38080

# JWT 密钥（生产环境必须修改！建议使用 32 位以上随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ============================================================
# AI 服务配置（可选）
# ============================================================

# Anthropic API Key
ANTHROPIC_AUTH_TOKEN=

# ============================================================
# 前端配置
# ============================================================

# 前端端口
FRONTEND_PORT=33000
