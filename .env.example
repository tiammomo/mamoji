# Mamoji 环境变量配置
# 复制此文件为 .env 并修改配置

# ===================
# 数据库配置
# ===================
MYSQL_ROOT_PASSWORD=mamoji_root_2024
MYSQL_DATABASE=mamoji
DB_USER=mamoji
DB_PASSWORD=mamoji123

# 端口配置
MYSQL_PORT=33306
REDIS_PORT=36379
BACKEND_PORT=38080
FRONTEND_PORT=33000

# ===================
# Spring Boot 配置
# ===================
SPRING_PROFILES_ACTIVE=dev

# ===================
# 安全配置（生产环境必须修改）
# ===================
JWT_SECRET=mamoji-jwt-secret-please-change-in-production-12345678901234567890

# ===================
# AI 配置
# ===================
ANTHROPIC_AUTH_TOKEN=your-minimax-api-key-here

# ===================
# 前端配置
# ===================
NEXT_PUBLIC_API_BASE=http://localhost:38080/api/v1

# ===================
# Redis 配置
# ===================
REDIS_PASSWORD=mamoji_redis_2024
