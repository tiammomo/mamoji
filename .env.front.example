# ========================
# Mamoji 前端环境配置模板
# ========================
# 复制此文件为 frontend/.env.local
# cp .env.front.example frontend/.env.local

# 项目名称
NEXT_PUBLIC_PROJECT_NAME=Mamoji - 家庭记账工具
NEXT_PUBLIC_VERSION=1.0.0

# 端口配置
NEXT_PUBLIC_FRONTEND_PORT=33000
NEXT_PUBLIC_BACKEND_PORT=38080

# API 配置
NEXT_PUBLIC_API_BASE=http://localhost:38080/api/v1
NEXT_PUBLIC_API_CORS=http://localhost:33000

# 测试账号
NEXT_PUBLIC_TEST_EMAIL=test@mamoji.com
NEXT_PUBLIC_TEST_NICKNAME=测试用户

# JWT 过期时间(秒)
NEXT_PUBLIC_JWT_EXPIRATION=86400
